# Claire de Binare local artifacts and generated output

# Historical broad test-file guard. Keep unchanged until scripts/test
# policy drift is cleaned up separately.
# Block ad-hoc test files in root/services
*test*.py
*test*.js
# Allow official test suite in tests/ directory (must come AFTER wildcard)
!tests/**/*.py
!tests/**/*.js
!services/validation/strategy_backtest_runner.py
!cdb_agent_sdk/tests/**/*.py
!cdb_agent_sdk/tests/**/*.js
debug_*.py
simple_test.*
quick_test.*
real_test*
*_backup.py

# Generated tool output files (local, do not version)
emoji-report.*
*.emoji-backup

# Governance work directories — historical/generated Codex workspaces.
# Retained locally for provenance; not canonical, not sweep targets.
