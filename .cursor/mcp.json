{
  "mcpServers": {
    "cdb_context": {
      "enabled": true,
      "command": ".venv/Scripts/python.exe",
      "args": ["-m", "tools.mcp.server"],
      "type": "stdio"
    },
    "redis": {
      "enabled": false,
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-redis"],
      "env": {
        "REDIS_PORT": "6379",
        "REDIS_HOST": "127.0.0.1"
      },
      "type": "stdio"
    }
  }
}
