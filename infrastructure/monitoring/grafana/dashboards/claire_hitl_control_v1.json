      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "daily_pnl_percent",
          "refId": "A",
          "legendFormat": "P&L %"
        },
        {
          "expr": "-5",
          "refId": "B",
          "legendFormat": "Circuit Breaker Limit"
