      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "risk_limit_max_daily_loss_percent",
          "refId": "A",
          "legendFormat": "Max Daily Loss (%)",
          "instant": true
        },
        {
          "expr": "risk_limit_max_exposure_percent",
          "refId": "B",
          "legendFormat": "Max Exposure (%)",
          "instant": true
        },
        {
          "expr": "risk_limit_max_position_size_usdt",
          "refId": "C",
          "legendFormat": "Max Position (USDT)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "unit": "short"
        }
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "Limit"
            }
          }
        }
      ]
    },
