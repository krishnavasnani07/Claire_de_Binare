{
  "uid": "claire_hitl_v1",
  "title": "Claire - HITL Control Center",
  "description": "ARCHIVED (legacy dashboard). Human-in-the-Loop monitoring and control dashboard for real-money trading operations",
  "tags": [
    "claire",
    "hitl",
    "control",
    "safety",
    "legacy"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  },
  "refresh": "10s",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "🚨 KILL-SWITCH STATUS",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kill_switch_active",
          "refId": "A",
          "legendFormat": "Kill-Switch"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "green",
                  "index": 0,
                  "text": "✅ INACTIVE"
                },
                "1": {
                  "color": "red",
                  "index": 1,
                  "text": "🚨 ACTIVE - TRADING STOPPED"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
