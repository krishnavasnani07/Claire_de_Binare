{
  "uid": "cdb_trading_performance_v1",
  "title": "CDB - Trading Performance",
  "description": "Minimal trading performance dashboard. Prometheus: system health + trade pipeline. PostgreSQL: equity/PnL from portfolio_snapshots (requires db_writer + paper_runner publishing snapshots via Redis).",
  "tags": ["cdb", "trading", "performance", "minimal"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m"]
  },
  "refresh": "1m",
  "style": "dark",
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "SYSTEM SAFETY",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 2,
      "type": "stat",
      "title": "SYSTEM HEALTH",
      "description": "min(up{job=~\"cdb_.*\"}) — 1 = all scraped services UP, 0 = at least one DOWN",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "min(up{job=~\"cdb_.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DEGRADED", "color": "red", "index": 0 },
                "1": { "text": "OK", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "CIRCUIT BREAKER",
      "description": "circuit_breaker_active — 0 = inactive (normal), 1 = ACTIVE (trading halted)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "circuit_breaker_active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "INACTIVE", "color": "green", "index": 0 },
                "1": { "text": "ACTIVE", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "KILL SWITCH",
      "description": "risk_kill_switch_active — 0 = off (normal), 1 = ACTIVE (all orders blocked)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "risk_kill_switch_active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OFF", "color": "green", "index": 0 },
                "1": { "text": "ACTIVE", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "PORTFOLIO — requires db_writer + portfolio_snapshots writes via Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 11,
      "type": "stat",
      "title": "EQUITY (latest)",
      "description": "total_equity from portfolio_snapshots — latest snapshot. No data = db_writer not writing snapshots.",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "rawSql": "SELECT total_equity AS \"Total Equity\" FROM portfolio_snapshots ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 12,
      "type": "stat",
      "title": "DAILY PnL (latest snapshot)",
      "description": "daily_pnl from portfolio_snapshots — latest row. Positive = green, negative = red.",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 6 },
      "targets": [
        {
          "rawSql": "SELECT daily_pnl AS \"Daily PnL\" FROM portfolio_snapshots ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 13,
      "type": "stat",
      "title": "REALIZED PnL (total)",
      "description": "total_realized_pnl from portfolio_snapshots — latest row.",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "rawSql": "SELECT total_realized_pnl AS \"Realized PnL\" FROM portfolio_snapshots ORDER BY timestamp DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 0.01 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "EQUITY CURVE",
      "description": "total_equity over time from portfolio_snapshots. No data = no snapshots written yet.",
      "datasource": { "type": "postgres", "uid": "postgres" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "rawSql": "SELECT timestamp AS \"time\", total_equity AS \"Total Equity\" FROM portfolio_snapshots WHERE $__timeFilter(timestamp) ORDER BY timestamp",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "TRADE PIPELINE (Prometheus)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 21,
      "type": "stat",
      "title": "ORDERS APPROVED",
      "description": "orders_approved_total — cumulative since service start",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "orders_approved_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 22,
      "type": "stat",
      "title": "ORDERS BLOCKED",
      "description": "orders_blocked_total — cumulative since service start",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "targets": [
        {
          "expr": "orders_blocked_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 23,
      "type": "stat",
      "title": "FILLS (execution)",
      "description": "execution_orders_filled_total — cumulative confirmed fills from execution service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "execution_orders_filled_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },

    {
      "id": 24,
      "type": "gauge",
      "title": "APPROVAL RATE %",
      "description": "orders_approved / signals_received — proxy for risk filter pass-through",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 19 },
      "targets": [
        {
          "expr": "100 * orders_approved_total / clamp_min(signals_received_total, 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    }

  ]
}
