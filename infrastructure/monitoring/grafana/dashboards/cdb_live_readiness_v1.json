{
  "uid": "cdb_live_readiness_v1",
  "title": "CDB Live-Readiness Execution Dashboard (Phases A/B/C)",
  "description": "Multi-phase visualization for evaluating readiness to transition from Paper to Shadow/Live Trading.",
  "tags": [
    "claire",
    "readiness",
    "phases",
    "live-gate"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m"
    ]
  },
  "style": "dark",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "DataSource",
        "current": {
            "text": "Prometheus",
            "value": "Prometheus"
        }
      },
      {
        "name": "environment",
        "type": "custom",
        "query": "paper,shadow,live",
        "label": "Environment",
        "current": {
            "text": "paper",
            "value": "paper"
        }
      },
      {
         "name": "symbol",
         "type": "custom",
         "query": "BTCUSDT,ETHUSDT",
         "label": "Symbol",
         "current": {
             "text": "BTCUSDT",
             "value": "BTCUSDT"
         }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "PHASE A: CONNECTIVITY & HEARTBEAT (The Pulse Gate)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Exchange Connectivity (WS)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "up{job=\"cdb_ws\"}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "value": 0, "color": "red" }, { "value": 1, "color": "green" } ]
          },
          "color": { "mode": "background" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redis Stream Lag",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "redis_stream_lag_seconds{stream=\"market_data\"}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
             "mode": "absolute",
             "steps": [ { "value": 0, "color": "green" }, { "value": 1, "color": "red" } ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Service Heartbeats",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "count(up{name=~\"cdb_.*\"} == 1)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "max": 9,
          "thresholds": {
             "mode": "absolute",
             "steps": [ { "value": 0, "color": "red" }, { "value": 9, "color": "green" } ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Container Restarts",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "sum(container_restart_count{name=~\"cdb_.*\"})", "refId": "A" } ],
      "fieldConfig": {
         "defaults": {
            "color": { "mode": "background" },
            "thresholds": {
               "mode": "absolute",
               "steps": [ { "value": 0, "color": "green" }, { "value": 1, "color": "red" } ]
            }
         }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "PHASE B: OPERATIONAL THROUGHPUT (The Logic Gate)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Signal-to-Order Conversion",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "rate(execution_orders_received_total[5m]) / rate(signals_generated_total[5m])", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
           "min": 0, "max": 1,
           "thresholds": {
              "mode": "absolute",
              "steps": [ { "value": 0, "color": "red" }, { "value": 0.8, "color": "green" } ]
           }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Risk Approval Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "1 - (rate(risk_rejections_total[5m]) / rate(signals_processed_total[5m]))", "refId": "A" } ],
      "fieldConfig": {
         "defaults": {
            "unit": "percentunit",
            "thresholds": {
               "mode": "absolute",
               "steps": [ { "value": 0, "color": "red" }, { "value": 0.95, "color": "green" } ]
            }
         }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Execution Latency (p99)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "execution_order_latency_ms{quantile=\"0.99\"}", "refId": "A" } ],
      "fieldConfig": {
         "defaults": {
            "unit": "ms",
            "thresholds": {
               "mode": "absolute",
               "steps": [ { "value": 0, "color": "green" }, { "value": 250, "color": "red" } ]
            }
         }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Data Staleness",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "datasource": "${datasource}",
      "targets": [ { "expr": "time() - last_market_data_timestamp", "refId": "A" } ],
      "fieldConfig": {
         "defaults": {
            "unit": "s",
            "thresholds": {
               "mode": "absolute",
               "steps": [ { "value": 0, "color": "green" }, { "value": 5, "color": "red" } ]
            }
         }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "PHASE C: PnL & SAFETY (The Capital Gate)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }
    },
    {
       "id": 21,
       "type": "stat",
       "title": "Current Drawdown",
       "gridPos": { "h": 4, "w": 6, "x": 0, "y": 11 },
       "datasource": "${datasource}",
       "targets": [ { "expr": "trading_drawdown_percentage", "refId": "A" } ],
       "fieldConfig": {
          "defaults": {
             "unit": "percent",
             "thresholds": {
                "mode": "absolute",
                "steps": [ { "value": 0, "color": "green" }, { "value": 5, "color": "red" } ]
             }
          }
       }
    },
    {
       "id": 22,
       "type": "stat",
       "title": "Fill Accuracy (Slippage)",
       "gridPos": { "h": 4, "w": 6, "x": 6, "y": 11 },
       "datasource": "${datasource}",
       "targets": [ { "expr": "(execution_fill_price - target_price) / target_price", "refId": "A" } ],
       "fieldConfig": {
          "defaults": {
             "unit": "percentunit",
             "thresholds": {
                "mode": "absolute",
                "steps": [ { "value": 0, "color": "green" }, { "value": 0.0005, "color": "red" } ]
             }
          }
       }
    },
    {
       "id": 23,
       "type": "stat",
       "title": "Position Drift",
       "gridPos": { "h": 4, "w": 6, "x": 12, "y": 11 },
       "datasource": "${datasource}",
       "targets": [ { "expr": "abs(actual_position_size - target_position_size)", "refId": "A" } ],
       "fieldConfig": {
          "defaults": {
             "unit": "percentunit",
             "thresholds": {
                "mode": "absolute",
                "steps": [ { "value": 0, "color": "green" }, { "value": 0.001, "color": "red" } ]
             }
          }
       }
    },
    {
       "id": 24,
       "type": "stat",
       "title": "Auto-Unwind Status",
       "gridPos": { "h": 4, "w": 6, "x": 18, "y": 11 },
       "datasource": "${datasource}",
       "targets": [ { "expr": "trading_auto_unwind_active", "refId": "A" } ],
       "fieldConfig": {
          "defaults": {
             "color": { "mode": "background" },
             "mappings": [
                 { "type": "value", "options": { "0": { "text": "NORMAL", "color": "green" }, "1": { "text": "TRIGGERED", "color": "red" } } }
             ]
          }
       }
    }
  ]
}
