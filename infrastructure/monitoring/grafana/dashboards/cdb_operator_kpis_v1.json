{
  "uid": "cdb_operator_kpis_v1",
  "title": "CDB - Operator KPIs",
  "description": "Minimal operator KPI slice for issue #203. PostgreSQL trades remain the canonical source. Positive-trade count and positive-trade rate are derived from repo-backed per-trade realized outcomes on exit executions.",
  "tags": [
    "cdb",
    "operator",
    "kpi",
    "issue-203"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "1h"
    ]
  },
  "refresh": "1m",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "MINIMAL KPI SLICE",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "TRADES MADE",
      "description": "Canonical operator count of trades with a realized outcome over the selected Grafana time range.",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE realized_pnl IS NOT NULL)::double precision AS \"Trades\" FROM trades WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "POSITIVE TRADES",
      "description": "Positive trade outcomes derived from trades.realized_pnl > 0 over the selected Grafana time range.",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE realized_pnl > 0)::double precision AS \"Positive Trades\" FROM trades WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "POSITIVE TRADES %",
      "description": "Derived win-rate style KPI from positive trades divided by all trades with a realized outcome over the selected Grafana time range.",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(100.0 * COUNT(*) FILTER (WHERE realized_pnl > 0) / NULLIF(COUNT(*) FILTER (WHERE realized_pnl IS NOT NULL), 0), 0.0) AS \"Positive Trade Rate\" FROM trades WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "TRADE OUTCOMES",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "TRADES MADE OVER TIME",
      "description": "Trades with a realized outcome grouped per hour from PostgreSQL trades over the selected Grafana time range.",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "rawSql": "SELECT $__timeGroupAlias(timestamp, '1h'), COUNT(*) FILTER (WHERE realized_pnl IS NOT NULL)::double precision AS \"Trades\" FROM trades WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "sum",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 7,
      "type": "text",
      "title": "KPI CONTRACT",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "options": {
        "mode": "markdown",
        "content": "- `Trades made`: rows in `trades` with non-null `realized_pnl`\n- `Positive trades`: rows in `trades` where `realized_pnl > 0`\n- `Positive trades %`: derived query over the same realized-outcome denominator\n\nIssue anchor: `#203`.\n\n`realized_pnl` is only set on exit executions. BUY/open-add rows stay out of these KPI counts until they carry a closed outcome."
      }
    }
  ]
}
