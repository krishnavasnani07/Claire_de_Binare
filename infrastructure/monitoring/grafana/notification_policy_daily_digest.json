{
  "receiver": "email-main",
  "group_by": ["alertname", "component", "issue"],
  "group_wait": "30s",
  "group_interval": "24h",
  "repeat_interval": "24h",
  "routes": [
    {
      "receiver": "email-main",
      "object_matchers": [
        ["severity", "=", "critical"]
      ],
      "group_by": ["alertname", "component", "issue"],
      "group_wait": "10s",
      "group_interval": "5m",
      "repeat_interval": "1h",
      "continue": false
    },
    {
      "receiver": "email-main",
      "object_matchers": [
        ["severity", "=", "warning"]
      ],
      "group_by": ["alertname", "component", "issue"],
      "group_wait": "5m",
      "group_interval": "24h",
      "repeat_interval": "24h",
      "continue": false
    }
  ],
  "provenance": "api"
}
