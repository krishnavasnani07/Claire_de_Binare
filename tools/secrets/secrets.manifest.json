{
  "version": 1,
  "canonical_secrets_path": "C:\\Users\\janne\\Documents\\.secrets\\.cdb",
  "defaults": {
    "rotation_command_default": "rotate apply",
    "forbid_include_manual": true
  },
  "secrets": [
    {
      "name": "REDIS_PASSWORD",
      "rotation_mode": "auto",
      "exclude_by_default": false,
      "format": "base64",
      "bytes": 24,
      "restart_scope": [
        "cdb_redis",
        "cdb_ws",
        "cdb_signal",
        "cdb_risk",
        "cdb_execution",
        "cdb_paper_runner",
        "cdb_core"
      ],
      "touch_policy": [],
      "notes": "Redis password used by all services for pub/sub and streams"
    },
    {
      "name": "POSTGRES_PASSWORD",
      "rotation_mode": "auto",
      "exclude_by_default": false,
      "format": "base64",
      "bytes": 24,
      "restart_scope": [
        "cdb_postgres"
      ],
      "touch_policy": [],
      "notes": "PostgreSQL database password"
    },
    {
      "name": "POSTGRES_PASSWORD_DSN",
      "rotation_mode": "auto",
      "exclude_by_default": false,
      "format": "base64",
      "bytes": 24,
      "restart_scope": [
        "cdb_postgres"
      ],
      "touch_policy": [],
      "notes": "PostgreSQL DSN password (may be same as POSTGRES_PASSWORD)"
    },
    {
      "name": "GRAFANA_ADMIN_PASSWORD",
      "rotation_mode": "manual",
      "exclude_by_default": true,
      "format": "manual",
      "bytes": null,
      "restart_scope": [
        "cdb_grafana"
      ],
      "touch_policy": [],
      "notes": "MANUAL: stored in password manager / browser; rotate only on incident via runbook"
    }
  ]
}
